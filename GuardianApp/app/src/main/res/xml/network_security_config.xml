<?xml version="1.0" encoding="utf-8"?>
<!--
    网络安全配置：
    - 默认禁止明文（cleartext）HTTP 传输，防止位置和 token 泄露
    - 仅对已知开发服务器 IP 允许明文（局域网调试专用）
    - 生产部署时请将服务端迁移至 HTTPS，并从下方 domain-config 中移除对应 IP
-->
<network-security-config>

    <!-- 默认策略：禁止所有明文流量 -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- 开发例外：仅允许已知局域网 IP 使用 HTTP（真机 flavor + 模拟器 flavor）-->
    <domain-config cleartextTrafficPermitted="true">
        <!-- 模拟器宿主机别名（10.0.2.2 固定指向 localhost） -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- 真机开发时后端所在局域网 IP（与 build.gradle device flavor 一致） -->
        <domain includeSubdomains="false">192.168.1.165</domain>
        <!-- 本机直连（PC 上直接运行测试时用） -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!-- Debug 构建额外信任用户安装的 CA 证书（自签 HTTPS 调试方便）-->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

</network-security-config>
